#@ Placement
#-    Configure a placement constraint to where the container will be run.
#-    Examples:
#-        - node.hostname==<hostname>
#-        - engine.labels.fs-access.<worker-hostname>.mnt==true
#-        - node.role!=manager
PLACEMENT_CONSTRAINT=node.platform.os==linux
#@ Host Config
#-  - TZ -
#-    The timezone.
TZ=Etc/UTC
#-  - NODE_CLUSTER -
#-    Optional cluster label attached to metrics when external labels
#-    are not explicitly overridden.
NODE_CLUSTER=default
#-  - DOCKER_SOCKET_PATH -
#-    Optional host path for the Docker socket mounted into vmagent.
DOCKER_SOCKET_PATH=/var/run/docker.sock
#@ Storage
#-  - PROM_AGENT_REMOTE_WRITE_MAX_DISK_USAGE -
#-    Max on-disk queue size per remote_write URL, e.g. 1GB or 500MiB
PROM_AGENT_REMOTE_WRITE_MAX_DISK_USAGE=1GB
#@ Scrape Config
#-  - PROM_AGENT_SCRAPE_INTERVAL -
#-    Scrape interval for node-exporter and cadvisor
PROM_AGENT_SCRAPE_INTERVAL=15s
#-  - PROM_AGENT_EXTERNAL_LABELS -
#-    External labels block (indented 4 spaces), e.g.:
#-      edge: "vps-1"
PROM_AGENT_EXTERNAL_LABELS=
#-  - PROM_AGENT_ADDITIONAL_SCRAPE_CONFIGS -
#-    Additional scrape_configs entries (indented 2 spaces)
PROM_AGENT_ADDITIONAL_SCRAPE_CONFIGS=
#@ Remote Write (Metrics Router or Endpoint)
#-  - METRICS_REMOTE_WRITE_URL -
#-    Metrics router remote_write URL, e.g.:
#-      https://router.example.com/api/v1/write
METRICS_REMOTE_WRITE_URL=
#-  - METRICS_REMOTE_WRITE_BASIC_AUTH_USER -
#-    Optional username for metrics router basic auth
METRICS_REMOTE_WRITE_BASIC_AUTH_USER=
#-  - METRICS_REMOTE_WRITE_BASIC_AUTH_PASS -
#-    Optional password for metrics router basic auth
METRICS_REMOTE_WRITE_BASIC_AUTH_PASS=
